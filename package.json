{
  "name": "@global-torque/design-tokens",
  "private": false,
  "version": "0.1.0-beta.2",
  "description": "Neutral design tokens generated deterministically from one DTCG source.",
  "keywords": [
    "design-tokens",
    "dtcg",
    "css",
    "tailwindcss"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "sideEffects": [
    "./dist/*.css"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node scripts/build.mjs",
    "lint": "eslint --max-warnings=0 scripts vitest.config.mjs",
    "format:check": "prettier --check \"scripts/**/*.mjs\" \"test-d/**/*.ts\" \"src/**/*.json\" \".github/**/*.{yml,json,md}\" \"docs/{rfcs,ossf}/**/*.md\" \"*.{json,md,yaml}\"",
    "format:write": "prettier --write \"scripts/**/*.mjs\" \"test-d/**/*.ts\" \"src/**/*.json\" \".github/**/*.{yml,json,md}\" \"docs/{rfcs,ossf}/**/*.md\" \"*.{json,md,yaml}\"",
    "test:run": "pnpm run build && vitest run",
    "test:unit": "pnpm run test:run",
    "test:tailwind:current": "pnpm run build && node scripts/verify-tailwind-current.mjs",
    "browser:install": "playwright install --with-deps chromium",
    "test:coverage": "pnpm run build && vitest run --coverage",
    "typecheck": "pnpm run build && tsc --noEmit -p tsconfig.json",
    "api:check": "api-extractor run --verbose && api-extractor run --config api-extractor.css.json --verbose && api-extractor run --config api-extractor.theme.json --verbose",
    "api:report:update": "pnpm run build && api-extractor run --local --verbose && api-extractor run --config api-extractor.css.json --local --verbose && api-extractor run --config api-extractor.theme.json --local --verbose",
    "docs:api": "pnpm run api:report:update && api-documenter markdown --input temp/root --output docs/api && api-documenter markdown --input temp/css --output docs/api-css && api-documenter markdown --input temp/theme --output docs/api-theme",
    "docs:check": "pnpm run api:check && node scripts/verify-api-docs.mjs",
    "package:lint": "publint && attw --pack . --profile esm-only",
    "content:check": "node scripts/verify-public-content.mjs",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:coverage && pnpm run build && pnpm run docs:check && pnpm run package:lint && pnpm run content:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jridgewell/gen-mapping": "0.3.13",
    "@jridgewell/trace-mapping": "0.3.31",
    "@microsoft/api-documenter": "7.30.7",
    "@microsoft/api-extractor": "7.58.9",
    "@playwright/test": "1.61.1",
    "@arethetypeswrong/cli": "0.18.5",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "4.1.7",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "eslint": "9.39.4",
    "jsonc-parser": "3.3.1",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "tailwindcss": "4.2.1",
    "typescript": "^6.0.2",
    "vitest": "4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/global-torque/design-tokens.git"
  },
  "homepage": "https://github.com/global-torque/design-tokens#readme",
  "bugs": {
    "url": "https://github.com/global-torque/design-tokens/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "docs/api",
    "docs/api-css",
    "docs/api-theme",
    "etc/design-tokens.api.md",
    "etc/design-tokens-css.api.md",
    "etc/design-tokens-theme.api.md",
    "SECURITY.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "types": "./dist/css.d.ts",
      "style": "./dist/index.css",
      "import": "./dist/css.js",
      "default": "./dist/index.css"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "style": "./dist/theme.css",
      "import": "./dist/theme.js",
      "default": "./dist/theme.css"
    },
    "./tokens.json": "./dist/tokens.json",
    "./source": "./dist/tokens.tokens.json"
  }
}
