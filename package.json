{
  "name": "@global-torque/design-tokens",
  "private": false,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "4.1.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/global-torque/design-tokens.git"
  },
  "homepage": "https://github.com/global-torque/design-tokens#readme",
  "bugs": {
    "url": "https://github.com/global-torque/design-tokens/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/index.css",
    "./theme": "./dist/theme.css",
    "./tokens.json": "./dist/tokens.json"
  }
}
