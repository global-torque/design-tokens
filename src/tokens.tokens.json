        "background-surface": { "$value": "{primitive.color.white}" },
        "background-subtle": { "$value": "{primitive.color.neutral-50}" },
        "background-elevated": { "$value": "{primitive.color.white}" },
        "background-overlay": { "$value": "{primitive.color.overlay}" },
        "foreground-default": { "$value": "{primitive.color.neutral-900}" },
