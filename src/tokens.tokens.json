    "spacing": {
      "$type": "dimension",
      "0": { "$value": { "value": 0, "unit": "px" } },
      "1": { "$value": { "value": 0.25, "unit": "rem" } },
      "2": { "$value": { "value": 0.5, "unit": "rem" } },
      "3": { "$value": { "value": 0.75, "unit": "rem" } },
      "4": { "$value": { "value": 1, "unit": "rem" } },
      "6": { "$value": { "value": 1.5, "unit": "rem" } },
      "8": { "$value": { "value": 2, "unit": "rem" } },
      "12": { "$value": { "value": 3, "unit": "rem" } }
    },
    "radius": {
      "$type": "dimension",
      "none": { "$value": { "value": 0, "unit": "px" } },
      "sm": { "$value": { "value": 0.25, "unit": "rem" } },
      "md": { "$value": { "value": 0.5, "unit": "rem" } },
      "lg": { "$value": { "value": 0.75, "unit": "rem" } },
      "full": { "$value": { "value": 9999, "unit": "px" } }
    },
    "font-family": {
      "$type": "fontFamily",
      "sans": {
        "$value": ["Inter", "ui-sans-serif", "system-ui", "sans-serif"]
      },
      "mono": {
        "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"]
      }
    },
    "font-size": {
      "$type": "dimension",
      "xs": { "$value": { "value": 0.75, "unit": "rem" } },
      "sm": { "$value": { "value": 0.875, "unit": "rem" } },
      "base": { "$value": { "value": 1, "unit": "rem" } },
      "lg": { "$value": { "value": 1.125, "unit": "rem" } },
      "xl": { "$value": { "value": 1.25, "unit": "rem" } },
      "2xl": { "$value": { "value": 1.5, "unit": "rem" } }
    },
    "font-weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "tight": { "$value": 1.25 },
      "normal": { "$value": 1.5 },
      "relaxed": { "$value": 1.625 }
    },
    "letter-spacing": {
      "$type": "dimension",
      "tight": { "$value": { "value": -0.015, "unit": "rem" } },
      "normal": { "$value": { "value": 0, "unit": "rem" } },
      "wide": { "$value": { "value": 0.025, "unit": "rem" } }
    },
    "opacity": {
      "$type": "number",
      "disabled": { "$value": 0.48 },
      "muted": { "$value": 0.72 }
    },
    "breakpoint": {
      "$type": "dimension",
      "sm": { "$value": { "value": 40, "unit": "rem" } },
      "md": { "$value": { "value": 48, "unit": "rem" } },
      "lg": { "$value": { "value": 64, "unit": "rem" } },
      "xl": { "$value": { "value": 80, "unit": "rem" } }
    },
    "duration": {
      "$type": "duration",
      "fast": { "$value": { "value": 120, "unit": "ms" } },
      "normal": { "$value": { "value": 180, "unit": "ms" } }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.2, 0, 0, 1] },
      "exit": { "$value": [0.4, 0, 1, 1] }
    },
    "animation": {
      "fade-in": {
        "$type": "duration",
        "$value": "{primitive.duration.normal}",
        "$extensions": {
          "org.global-torque.css": {
            "name": "gt-fade-in",
            "easing": "{primitive.easing.standard}",
            "fillMode": "both",
            "keyframes": {
              "from": { "opacity": 0 },
              "to": { "opacity": 1 }
            }
          }
        }
      }
    },
    "shadow": {
      "$type": "shadow",
      "sm": {
        "$value": {
          "color": {
            "colorSpace": "srgb",
            "components": [0.0588, 0.0902, 0.1647],
            "alpha": 0.12
          },
          "offsetX": { "value": 0, "unit": "px" },
          "offsetY": { "value": 1, "unit": "px" },
          "blur": { "value": 2, "unit": "px" },
          "spread": { "value": 0, "unit": "px" }
        }
      },
      "md": {
        "$value": [
          {
            "color": {
              "colorSpace": "srgb",
              "components": [0.0588, 0.0902, 0.1647],
              "alpha": 0.12
            },
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 4, "unit": "px" },
            "blur": { "value": 12, "unit": "px" },
            "spread": { "value": -2, "unit": "px" }
          },
          {
            "color": {
              "colorSpace": "srgb",
              "components": [0.0588, 0.0902, 0.1647],
              "alpha": 0.08
            },
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 2, "unit": "px" },
            "blur": { "value": 4, "unit": "px" },
            "spread": { "value": -1, "unit": "px" }
          }
        ]
      }
    }
  },
  "semantic": {
    "$description": "Host-facing meaning with explicit light and dark modes.",
